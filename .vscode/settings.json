{
  // 저장 시 자동으로 코드 포맷팅을 실행합니다.
  "editor.formatOnSave": true,
  // 저장 시 ESLint 자동 수정을 실행합니다.
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  // 기본 포맷터로 Prettier를 설정합니다.
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // JavaScript, TypeScript, JSX, TSX 파일에 대해 Prettier를 기본 포맷터로 지정합니다.
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // 파일의 줄 바꿈 형식을 LF로 통일합니다.
  "files.eol": "\n",

  // material icon custom
  "material-icon-theme.folders.associations": {
    "_components": "Components",
    "_constants": "Constant",
    "_hooks": "Hook",
    "_service": "Api",
    "_store": "Container",
    "_types": "Typescript",
    "_utils": "Utils",
    "(route)": "Routes"
  }
}
